DATABASE_URL="postgresql://normativo:normativo@localhost:5432/normativo?schema=public"
TEST_DATABASE_URL="postgresql://normativo:normativo@localhost:5433/normativo_test?schema=public"

# Ingesta Registro Oficial (Fase 5A). Límites operativos, no reglas de dominio.
INGESTA_MAX_ENTRADAS=1500
HTTP_JSON_BODY_LIMIT="8mb"

# Autenticación (Fase 4A). Valores de ejemplo, NO secretos reales.
# En producción JWT_SECRET es obligatorio (mínimo 32 caracteres).
# Fuera de producción, si se omite, la app usa un secreto explícito de desarrollo.
JWT_SECRET="cambia-este-secreto-de-ejemplo-por-uno-de-32+chars"
# Opcionales: si se definen, el verificador los exige en los tokens.
# JWT_ISSUER="normativo"
# JWT_AUDIENCE="api-normativo"

# Bootstrap operativo del SUPERADMINISTRADOR (Fase 4E). Valores de ejemplo,
# NO secretos reales. Requiere confirmación explícita para ejecutarse.
# PERMITIR_BOOTSTRAP_SUPERADMIN=true
# BOOTSTRAP_SUPERADMIN_CORREO="superadmin@ejemplo.com"
# BOOTSTRAP_SUPERADMIN_PASSWORD="cambia-esta-contrasena-larga"
# Opcionales (tienen valores por defecto):
# BOOTSTRAP_SUPERADMIN_ID="usuario-superadmin-inicial"
# BOOTSTRAP_SUPERADMIN_NOMBRE="Superadministrador"
# BOOTSTRAP_SUPERADMIN_APELLIDO="Inicial"
# Solo para bases remotas/productivas (decisión operativa consciente):
# PERMITIR_BOOTSTRAP_SUPERADMIN_NO_LOCAL=true
